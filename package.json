{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:content && vite",
    "build": "pnpm build:content && tsc -b && vite build && pnpm build:feed && pnpm build:ogp",
    "build:content": "contentlayer2 build",
    "build:feed": "tsx scripts/build-feed.ts",
    "build:ogp": "tsx scripts/build-ogp.ts",
    "preview": "pnpm build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "versions:upload": "pnpm build && wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -b --noEmit",
    "test:e2e": "playwright test --ignore-snapshots --grep-invert 'Visual Regression'",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:server": "pnpm build && wrangler dev --port 8787"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.94.0",
    "autoprefixer": "10.4.23",
    "contentlayer2": "^0.5.8",
    "dayjs": "^1.11.21",
    "dayjs-plugin-utc": "^0.1.2",
    "feed": "^5.2.1",
    "lucide-react": "^0.562.0",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^1.29.2",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/vite-plugin": "^1.43.0",
    "@playwright/test": "^1.57.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tanstack/react-query-devtools": "^5.62.0",
    "@tanstack/react-router-devtools": "^1.94.0",
    "@tanstack/router-plugin": "^1.94.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "lint-staged": "^16.2.7",
    "sass": "^1.97.2",
    "satori": "^0.19.0",
    "tsx": "^4.20.6",
    "vite": "^6.0.0",
    "wrangler": "^4.107.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "protobufjs",
      "workerd",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
