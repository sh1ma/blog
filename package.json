{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "next-on-pages": "next-on-pages",
    "dev": "next dev",
    "build": "next build",
    "build:content": "contentlayer2 build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "test:e2e": "playwright test --ignore-snapshots --grep-invert 'Visual Regression'",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:server": "pnpm preview"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.14.8",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "10.4.23",
    "contentlayer2": "^0.5.8",
    "dayjs": "^1.11.21",
    "dayjs-plugin-utc": "^0.1.2",
    "feed": "^5.2.1",
    "lucide-react": "^0.562.0",
    "next": "15.5.19",
    "next-contentlayer2": "^0.5.8",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^1.29.2",
    "tailwindcss": "^3.4.19",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@next/bundle-analyzer": "15.5.19",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "lint-staged": "^16.2.7",
    "sass": "^1.97.2",
    "wrangler": "^4.96.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.16",
      "@types/react-dom": "19.2.3"
    },
    "onlyBuiltDependencies": [
      "protobufjs",
      "workerd"
    ]
  }
}
