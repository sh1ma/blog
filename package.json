{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm gen && tsc -b && vite build && pnpm build:feed && pnpm build:sitemap && pnpm build:ogp",
    "gen": "pnpm build:content && pnpm build:routes",
    "build:content": "content-collections build",
    "build:routes": "tsr generate",
    "build:feed": "tsx scripts/build-feed.ts",
    "build:sitemap": "tsx scripts/build-sitemap.ts",
    "build:ogp": "tsx scripts/build-ogp.ts",
    "preview": "pnpm build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "versions:upload": "pnpm build && wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "pnpm gen && tsc -b --noEmit",
    "test:e2e": "playwright test --ignore-snapshots --grep-invert 'Visual Regression'",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:server": "pnpm build && wrangler dev --port 8787"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-router": "^1.170.18",
    "dayjs": "^1.11.21",
    "dayjs-plugin-utc": "^0.1.2",
    "feed": "^5.2.1",
    "katex": "^0.18.1",
    "lucide-react": "^0.577.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.4",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@content-collections/cli": "^0.1.9",
    "@content-collections/core": "^0.15.2",
    "@content-collections/markdown": "^0.1.4",
    "@content-collections/vite": "^0.3.0",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/react-query-devtools": "^5.101.4",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-cli": "^1.167.21",
    "@tanstack/router-plugin": "^1.168.23",
    "@types/hast": "^3.0.5",
    "@types/node": "^24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "lint-staged": "^16.4.0",
    "satori": "^0.28.1",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^6.4.3",
    "wrangler": "^4.112.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3",
      "js-yaml@<3.15.0": "^3.15.0"
    },
    "onlyBuiltDependencies": [
      "protobufjs",
      "workerd",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
